model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
  role  String
  holidays Holiday[]
}

model Holiday {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  status    String   @default("pending")

  userId Int
  user   User @relation(fields: [userId], references: [id])
}